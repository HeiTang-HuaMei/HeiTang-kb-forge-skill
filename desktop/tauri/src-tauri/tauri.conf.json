{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeiTang KB Forge Desktop",
  "version": "1.2.3",
  "identifier": "com.heitang.kbforge",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../../web/workbench/flutter_app/build/web"
  },
  "app": {
    "windows": [
      {
        "title": "HeiTang KB Forge Desktop",
        "width": 1040,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
