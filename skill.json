{
  "name": "heitang-kb-forge-skill",
  "display_name": "HeiTang KB Forge Skill",
  "version": "1.6.1",
  "description": "Agent knowledge supply-chain Skill for producing standardized, auditable, retrievable knowledge packages.",
  "entrypoints": {
    "cli": "heitang-kb-forge",
    "python_module": "python -m heitang_kb_forge.cli"
  },
  "capabilities": [
    "build_knowledge_package",
    "batch_build_packages",
    "knowledge_lifecycle_check",
    "local_knowledge_store",
    "agent_rag_retrieve",
    "agent_ask",
    "agent_tool_export",
    "mcp_readiness_export"
  ],
  "input_types": ["md", "txt", "pdf", "docx", "png", "jpg", "jpeg", "csv", "tsv", "xlsx"],
  "output_contract": [
    "chunks.jsonl",
    "cards.jsonl",
    "qa_pairs.jsonl",
    "glossary.jsonl",
    "manifest.json",
    "quality_report.json",
    "ingest_report.md"
  ],
  "optional_extras": ["ocr", "pdf-table", "web", "dev"],
  "agent_targets": ["OpenClaw", "Claude Code", "Codex", "Generic Agent", "MCP-ready"],
  "network_required_by_default": false
}
