{
  "name": "heitang-kb-forge-skill",
  "display_name": "HeiTang KB Forge Skill",
  "version": "4.0.0rc1",
  "description": "Local-first knowledge workbench Core Skill for producing, auditing, retrieving, generating, and validating knowledge packages for the v4.0.0-rc.1 release candidate.",
  "entrypoints": {
    "cli": "heitang-kb-forge",
    "python_module": "python -m heitang_kb_forge.cli"
  },
  "capabilities": [
    "build_knowledge_package",
    "batch_build_packages",
    "knowledge_lifecycle_check",
    "evidence_gate",
    "quality_report",
    "release_quality_gate",
    "regression_check",
    "release_blockers"
  ],
  "preview_capabilities": [
    "rag_export",
    "agent_rag_retrieve",
    "agent_ask",
    "local_workspace_registry",
    "knowledge_governance",
    "platform_distribution",
    "xhs_skill_package_mock",
    "agent_tool_export",
    "mcp_stub_export",
    "parser_backend_abstraction",
    "parser_backend_compare",
    "parse_quality_gate",
    "knowledge_reliability_gate",
    "knowledge_runtime_loop",
    "kb_index_query_answer",
    "document_generation_loop",
    "query_rewrite_retrieval_planning",
    "retrieval_quality_evaluation",
    "knowledge_accuracy_verification",
    "workspace_storage_memory_lifecycle",
    "local_agent_runtime_mother_child",
    "golden_demo_acceptance",
    "product_hardening_release_readiness"
  ],
  "experimental_capabilities": [
    "master_skill_learning",
    "derived_skill_generator",
    "llm_quality_assist",
    "provider_readiness",
    "prompt_profile_versioning",
    "golden_samples",
    "compatibility_matrix",
    "llm_live_smoke",
    "provider_security_governance",
    "provider_registry_governance",
    "provider_fallback_test",
    "llm_cost_guard",
    "audit_redaction_check",
    "demo_e2e_portfolio_release",
    "minimal_e2e_demo",
    "desktop_web_ui",
    "pre_v4_industrial_acceptance_audit"
  ],
  "roadmap_capabilities": [
    "runtime_compatibility_hardening",
    "domain_skill_factory_future",
    "future_client_platform_integrations",
    "saas_permissions_team_collaboration_v3x",
    "saas_permissions_team_collaboration_future",
    "byo_cloud_storage_future",
    "local_db_storage_future"
  ],
  "input_types": ["md", "txt", "pdf", "docx", "png", "jpg", "jpeg", "csv", "tsv", "xlsx", "html", "epub", "zip"],
  "output_contract": [
    "chunks.jsonl",
    "cards.jsonl",
    "qa_pairs.jsonl",
    "glossary.jsonl",
    "manifest.json",
    "quality_report.json",
    "ingest_report.md"
  ],
  "optional_extras": ["ocr", "pdf-table", "parser-docling", "parser-marker", "web", "dev"],
  "agent_targets": ["OpenClaw", "Claude Code", "Codex", "Generic Agent", "MCP-ready"],
  "network_required_by_default": false,
  "real_platform_publish_by_default": false,
  "stores_real_api_keys": false
}

