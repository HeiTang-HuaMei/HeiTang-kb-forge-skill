{
  "schema_version": "validation_gate_manifest.v1",
  "release_version": "v4.2.0",
  "release_title": "P2.2 Knowledge-to-Methodology-to-Skill-Suite Industrial Baseline",
  "log_root": "docs/audits/test_engineering",
  "runner_module": "heitang_kb_forge.test_governance.gates",
  "default_phase": "development",
  "phases": ["development", "phase_closure", "release"],
  "default_gates": {
    "development": ["core_fast_test_governance"],
    "phase_closure": ["core_medium_release_truth"]
  },
  "pytest_markers": [
    "fast",
    "medium",
    "full",
    "docs_truth",
    "parser_backend",
    "release",
    "ui_contract",
    "slow"
  ],
  "gates": [
    {
      "name": "core_fast_docs_truth",
      "level": "fast",
      "repository": "core",
      "command": "python -m pytest tests/test_final_docs_truthfulness.py tests/test_final_bilingual_docs_parity.py tests/test_final_docs_structure.py tests/test_release_checklist_docs.py tests/test_readme_scope.py tests/test_version_alignment.py tests/test_version_matrix_docs.py -q",
      "log_path": "docs/audits/test_engineering/fast_gate_logs/core_fast_docs_truth.log",
      "exit_code_required": true,
      "release_blocking": false,
      "impacted_surfaces": ["docs_truth", "version_truth", "release_checklist"]
    },
    {
      "name": "core_fast_test_governance",
      "level": "fast",
      "repository": "core",
      "command": "python -m pytest tests/test_test_governance_manifest.py -q",
      "log_path": "docs/audits/test_engineering/fast_gate_logs/core_fast_test_governance.log",
      "exit_code_required": true,
      "release_blocking": false,
      "impacted_surfaces": ["test_governance", "validation_runner"]
    },
    {
      "name": "core_fast_parser_backend",
      "level": "fast",
      "repository": "core",
      "command": "python -m pytest tests/test_v28_parser_backends.py -q",
      "log_path": "docs/audits/test_engineering/fast_gate_logs/core_fast_parser_backend.log",
      "exit_code_required": true,
      "release_blocking": false,
      "impacted_surfaces": ["parser_backend"]
    },
    {
      "name": "core_fast_doctor_release_readiness",
      "level": "fast",
      "repository": "core",
      "command": "python -m pytest tests/test_doctor_command.py tests/test_doctor_cli.py tests/test_release_readiness_gate.py -q",
      "log_path": "docs/audits/test_engineering/fast_gate_logs/core_fast_doctor_release_readiness.log",
      "exit_code_required": true,
      "release_blocking": false,
      "impacted_surfaces": ["doctor_diagnostics", "release_readiness"]
    },
    {
      "name": "core_medium_release_truth",
      "level": "medium",
      "repository": "core",
      "command": "python -m pytest tests/test_final_docs_truthfulness.py tests/test_final_bilingual_docs_parity.py tests/test_final_docs_structure.py tests/test_release_checklist_docs.py tests/test_readme_scope.py tests/test_version_alignment.py tests/test_version_matrix_docs.py tests/test_final_version_metadata.py tests/test_skill_metadata.py tests/test_v12_docs.py tests/test_test_governance_manifest.py -q",
      "log_path": "docs/audits/test_engineering/medium_gate_logs/core_medium_release_truth.log",
      "exit_code_required": true,
      "release_blocking": false,
      "impacted_surfaces": ["docs_truth", "version_truth", "test_governance", "release_checklist"]
    },
    {
      "name": "core_full_docs_truth_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest tests/test_final_docs_truthfulness.py tests/test_final_bilingual_docs_parity.py tests/test_final_docs_structure.py tests/test_release_checklist_docs.py tests/test_readme_scope.py tests/test_version_alignment.py tests/test_version_matrix_docs.py tests/test_final_version_metadata.py tests/test_skill_metadata.py tests/test_v12_docs.py tests/test_test_governance_manifest.py -q",
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_docs_truth_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["docs_truth", "version_truth", "test_governance", "release_checklist"]
    },
    {
      "name": "core_full_parser_backend_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest tests/test_v28_parser_backends.py tests/test_external_project_registry.py tests/test_planned_adapter_boundaries.py tests/test_s_a_contract_inclusion.py tests/test_post_v4_external_roadmap.py -q",
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_parser_backend_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["parser_backend", "external_registry_boundaries"]
    },
    {
      "name": "core_full_a_c_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest -q",
      "test_file_patterns": ["tests/test_a*.py", "tests/test_b*.py", "tests/test_c*.py"],
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_a_c_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["full_core_regression"]
    },
    {
      "name": "core_full_d_f_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest -q",
      "test_file_patterns": ["tests/test_d*.py", "tests/test_e*.py", "tests/test_f*.py"],
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_d_f_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["full_core_regression"]
    },
    {
      "name": "core_full_g_m_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest -q",
      "test_file_patterns": [
        "tests/test_g*.py",
        "tests/test_h*.py",
        "tests/test_i*.py",
        "tests/test_j*.py",
        "tests/test_k*.py",
        "tests/test_l*.py",
        "tests/test_m*.py"
      ],
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_g_m_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["full_core_regression"]
    },
    {
      "name": "core_full_n_s_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest -q",
      "test_file_patterns": [
        "tests/test_n*.py",
        "tests/test_o*.py",
        "tests/test_p*.py",
        "tests/test_q*.py",
        "tests/test_r*.py",
        "tests/test_s*.py"
      ],
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_n_s_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["full_core_regression"]
    },
    {
      "name": "core_full_t_z_chunk",
      "level": "chunked_full",
      "repository": "core",
      "command": "python -m pytest -q",
      "test_file_patterns": [
        "tests/test_t*.py",
        "tests/test_u*.py",
        "tests/test_v*.py",
        "tests/test_w*.py",
        "tests/test_x*.py",
        "tests/test_y*.py",
        "tests/test_z*.py"
      ],
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_full_t_z_chunk.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["full_core_regression"]
    },
    {
      "name": "core_git_diff_check",
      "level": "chunked_full",
      "repository": "core",
      "command": "git diff --check",
      "log_path": "docs/audits/test_engineering/full_gate_logs/core_git_diff_check.log",
      "exit_code_required": true,
      "release_blocking": true,
      "impacted_surfaces": ["release_hygiene"]
    }
  ],
  "impact_rules": [
    {
      "name": "test_governance",
      "patterns": [
        "docs/testing/**",
        "heitang_kb_forge/test_governance/**",
        "tests/test_test_governance_manifest.py",
        "pyproject.toml"
      ],
      "impacted_surfaces": ["test_governance", "validation_runner"],
      "fast_gates": ["core_fast_test_governance", "core_fast_docs_truth"],
      "medium_gates": ["core_medium_release_truth"],
      "full_gate_required_before_release": true
    },
    {
      "name": "docs_truth",
      "patterns": ["README*.md", "docs/**", "skill.json"],
      "impacted_surfaces": ["docs_truth", "version_truth"],
      "fast_gates": ["core_fast_docs_truth"],
      "medium_gates": ["core_medium_release_truth"],
      "full_gate_required_before_release": true
    },
    {
      "name": "parser_backend",
      "patterns": [
        "heitang_kb_forge/parser_backends/**",
        "docs/audits/p2_1_parser_ocr_backends/**",
        "tests/test_v28_parser_backends.py"
      ],
      "impacted_surfaces": ["parser_backend"],
      "fast_gates": ["core_fast_parser_backend"],
      "medium_gates": ["core_fast_parser_backend", "core_fast_docs_truth"],
      "full_gate_required_before_release": true
    },
    {
      "name": "doctor_release_readiness",
      "patterns": [
        "heitang_kb_forge/doctor.py",
        "heitang_kb_forge/release_readiness/**",
        "tests/test_doctor*.py",
        "tests/test_release_readiness_gate.py"
      ],
      "impacted_surfaces": ["doctor_diagnostics", "release_readiness"],
      "fast_gates": ["core_fast_doctor_release_readiness"],
      "medium_gates": ["core_fast_doctor_release_readiness", "core_medium_release_truth"],
      "full_gate_required_before_release": true
    },
    {
      "name": "version_metadata",
      "patterns": ["pyproject.toml", "skill.json", "docs/VERSION_MATRIX*.md", "tests/test_version_alignment.py"],
      "impacted_surfaces": ["version_truth", "release_checklist"],
      "fast_gates": ["core_fast_docs_truth"],
      "medium_gates": ["core_medium_release_truth"],
      "full_gate_required_before_release": true
    },
    {
      "name": "ci_or_release_workflow",
      "patterns": [".github/workflows/**", "heitang_kb_forge/release*.py", "docs/RELEASE_CHECKLIST*.md"],
      "impacted_surfaces": ["release_gate", "ci_workflow"],
      "fast_gates": ["core_fast_docs_truth"],
      "medium_gates": ["core_medium_release_truth"],
      "full_gate_required_before_release": true
    }
  ],
  "release_gate_sequence": [
    "core_full_docs_truth_chunk",
    "core_full_parser_backend_chunk",
    "core_full_a_c_chunk",
    "core_full_d_f_chunk",
    "core_full_g_m_chunk",
    "core_full_n_s_chunk",
    "core_full_t_z_chunk",
    "core_git_diff_check"
  ],
  "post_codex_review_gate": {
    "required": true,
    "levels": {
      "light": {
        "when": "after_each_task",
        "target_duration": "1-3 minutes",
        "outputs": ["P0", "P1", "P2"]
      },
      "medium": {
        "when": "after_phase_closure",
        "target_duration": "5-15 minutes",
        "outputs": ["P0", "P1", "P2"],
        "p3_policy": "backlog_only_non_blocking"
      },
      "full": {
        "when": "before_tag_or_release",
        "required_before": ["v4.2.0 tag", "v4.2.0 release"],
        "outputs": ["P0", "P1", "P2"],
        "p3_policy": "backlog_only_non_blocking"
      }
    },
    "issue_schema": [
      "id",
      "severity",
      "surface",
      "file/path",
      "evidence",
      "impact",
      "recommended_fix",
      "blocks_release"
    ],
    "stop_conditions": [
      "P0 = 0",
      "P1 = 0",
      "P2 fixed or explicitly deferred",
      "P3 recorded as non-blocking backlog",
      "fixes have corresponding Fast/Medium Gate evidence",
      "no new scope added"
    ],
    "release_rule": "Full Review must have no release-blocking P0/P1/P2 issues before tag/release."
  },
  "reporting_policy": {
    "never_report_skipped_or_deferred_as_passed": true,
    "required_command_fields": ["command", "exit_code", "status", "log_path", "summary"],
    "allowed_status": ["passed", "failed", "not_run", "deferred", "blocked", "env_blocked", "tool_unavailable"],
    "allowed_non_pass_status": ["not_run", "deferred", "blocked", "env_blocked", "tool_unavailable", "failed"],
    "forbidden_skip_reasons": ["passed by default", "assumed passed", "probably unrelated", "skip because slow"]
  },
  "obsolete_test_pruning": {
    "register": "docs/testing/TEST_PRUNING_REGISTER.md",
    "rule": "Do not delete a test until the replacement canonical invariant and validation gate are named.",
    "preferred_replacements": ["semantic_assertion", "structured_contract_assertion", "canonical_truth_source"]
  }
}
