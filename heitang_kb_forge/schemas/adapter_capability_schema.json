{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adapter_capability_schema.json",
  "title": "Document Backend Adapter Capability",
  "allOf": [
    {"$ref": "#/$defs/contract"},
    {
      "type": "object",
      "properties": {
        "schema_version": {"const": "document_backend.capability.v1"}
      }
    }
  ],
  "$defs": {
    "capabilitySupport": {
      "enum": ["supported", "partial", "unsupported", "unknown"]
    },
    "contract": {
      "type": "object",
      "required": [
        "schema_version",
        "adapter_id",
        "adapter_name",
        "adapter_version",
        "adapter_type",
        "integration_decision",
        "dependency_name",
        "optional_extra",
        "dependency_status",
        "runtime_status",
        "supported_inputs",
        "validated_inputs",
        "supported_outputs",
        "ocr_support",
        "layout_support",
        "table_support",
        "figure_support",
        "formula_support",
        "reading_order_support",
        "confidence",
        "warnings",
        "errors",
        "source_trace",
        "fallback_reason",
        "fallback_result",
        "repair_suggestion"
      ],
      "properties": {
        "schema_version": {"type": "string"},
        "adapter_id": {"type": "string", "minLength": 1},
        "adapter_name": {"type": "string", "minLength": 1},
        "adapter_version": {"type": "string", "minLength": 1},
        "adapter_type": {"type": "string", "minLength": 1},
        "integration_decision": {
          "enum": ["real_integration", "reference_only", "needs_strengthening", "stop_integration"]
        },
        "dependency_name": {"type": ["string", "null"]},
        "optional_extra": {"type": ["string", "null"]},
        "dependency_status": {"enum": ["bundled", "available", "missing", "unknown"]},
        "runtime_status": {"enum": ["ready", "disabled", "skipped", "failed", "unknown"]},
        "supported_inputs": {"type": "array", "items": {"type": "string"}},
        "validated_inputs": {"type": "array", "items": {"type": "string"}},
        "supported_outputs": {"type": "array", "items": {"type": "string"}},
        "ocr_support": {"$ref": "#/$defs/capabilitySupport"},
        "layout_support": {"$ref": "#/$defs/capabilitySupport"},
        "table_support": {"$ref": "#/$defs/capabilitySupport"},
        "figure_support": {"$ref": "#/$defs/capabilitySupport"},
        "formula_support": {"$ref": "#/$defs/capabilitySupport"},
        "reading_order_support": {"$ref": "#/$defs/capabilitySupport"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"$ref": "adapter_error_schema.json"}},
        "source_trace": {"type": "array", "items": {"type": "object"}},
        "fallback_reason": {"type": ["string", "null"]},
        "fallback_result": {"type": ["string", "null"]},
        "repair_suggestion": {"type": ["string", "null"]}
      }
    }
  },
  "unevaluatedProperties": false
}
